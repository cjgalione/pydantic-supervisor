OPENAI_API_KEY=""
TAVILY_API_KEY=""
BRAINTRUST_API_KEY=""
BRAINTRUST_PROJECT_ID="<your-braintrust-project-id>"
BRAINTRUST_PROJECT="pydantic-supervisor"
BRAINTRUST_ORG_NAME="<your-braintrust-org-name>"
MODAL_APP_NAME="curtis-pydantic-supervisor-eval-server"
TRACE_PROFILE="full"

# Route OpenAI SDK calls through the Braintrust gateway so all LLM traffic is
# logged in traces. Set OPENAI_API_KEY to your Braintrust API key (the gateway
# authenticates with it). Anthropic models are routed at the code level in
# resolve_model_name() since the Anthropic SDK's URL construction is
# incompatible with the gateway's endpoint structure.
OPENAI_BASE_URL="https://gateway.braintrust.dev/v1/proxy"
OPENAI_API_KEY=""
