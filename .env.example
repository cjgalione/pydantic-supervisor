GEMINI_API_KEY=""
GOOGLE_API_KEY=""
OPENAI_API_KEY=""
TAVILY_API_KEY=""
BRAINTRUST_API_KEY=""
BRAINTRUST_PROJECT_ID="<your-braintrust-project-id>"
BRAINTRUST_PROJECT="pydantic-supervisor"
BRAINTRUST_ORG_NAME="<your-braintrust-org-name>"
MODAL_APP_NAME="curtis-pydantic-supervisor-eval-server"
TRACE_PROFILE="full"

# Route Anthropic and OpenAI SDK calls through the Braintrust gateway so all
# LLM traffic is logged and visible in traces. The SDKs pick up these base URL
# overrides automatically. The API keys must be the Braintrust API key (not the
# real provider keys) because the gateway authenticates with it.
ANTHROPIC_BASE_URL="https://gateway.braintrust.dev/v1/proxy/anthropic"
ANTHROPIC_API_KEY=""
OPENAI_BASE_URL="https://gateway.braintrust.dev/v1/proxy"
OPENAI_API_KEY=""
